rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.keys().size() <= 3
        && data.email is string
        && data.email.size() <= 200
        && (data.get('displayName', '') is string)
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
                    && isValidId(userId)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
                    && (incoming().get('displayName', '') is string);
    }

    function isValidPrepDeck(data) {
        return data.keys().hasAll(['userId', 'company', 'role', 'level', 'round', 'categories', 'createdAt', 'updatedAt'])
            && data.keys().size() <= 9
            && data.userId is string && data.userId == request.auth.uid
            && data.company is string && data.company.size() <= 100
            && data.role is string && data.role.size() <= 100
            && data.level is string && data.level.size() <= 100
            && data.round is string && data.round.size() <= 100
            && data.categories is string && data.categories.size() <= 100000 
            && (data.get('industry', '') is string)
            && data.createdAt is timestamp
            && data.updatedAt is timestamp;
    }

    match /prepDecks/{deckId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && isValidId(deckId)
                    && isValidPrepDeck(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      allow update: if false; // Decks are immutable for now once saved
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    function isValidMockInterview(data) {
        return data.keys().hasAll(['userId', 'deckId', 'feedback', 'createdAt'])
            && data.keys().size() <= 5
            && data.userId is string && data.userId == request.auth.uid
            && data.deckId is string && data.deckId.size() <= 128
            && data.feedback is string && data.feedback.size() <= 50000
            && (data.get('score', 0) is number)
            && data.createdAt is timestamp;
    }

    match /mockInterviews/{interviewId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && isValidId(interviewId)
                    && isValidMockInterview(incoming())
                    && incoming().createdAt == request.time;
      allow update: if false;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
